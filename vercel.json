{
  "outputDirectory": ".",
  "redirects": [
    { "source": "/privacy-policy", "destination": "/privacy", "permanent": true },
    { "source": "/privacy-policy.html", "destination": "/privacy", "permanent": true },
    { "source": "/for-professionals", "destination": "/for-pros", "permanent": true },
    { "source": "/pro/register", "destination": "/pros/signup", "permanent": true },
    { "source": "/pro/login", "destination": "/pros/login", "permanent": true },
    { "source": "/charlotte", "destination": "/request?city=charlotte-nc", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://fixloapp.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/social/scheduler/run",
      "schedule": "*/15 * * * *"
    }
  ]
}
